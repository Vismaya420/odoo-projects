<odoo>
    <record id="view_account_move_form_purchase_rental" model="ir.ui.view">
        <field name="name">account.move.form.purchase.rental</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='checked']" position="after">
                    <field name="purchase_rental_id"/>
            </xpath>
        </field>
    </record>
</odoo>
